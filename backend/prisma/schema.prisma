generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COLLEGE_ADMIN
  DEPT_ADMIN
  FACULTY
  STUDENT
}

enum UserStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  name          String
  role          Role         @default(STUDENT)
  status        UserStatus   @default(ACTIVE)
  
  // Basic Info
  studentId     String?      @unique
  phone         String?
  gender        String?
  dob           DateTime?
  address       String?
  profileImage  String?
  
  // Academic Info
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  departmentId  String?
  dept          Department?  @relation("UserDept", fields: [departmentId], references: [id])
  hodOf         Department[] @relation("DeptHOD")
  department    String?      // Keep for backward compatibility or direct access
  course        String?
  semester      String?
  batch         String?
  
  // Proctoring & Security
  faceRegistered   Boolean   @default(false)
  webcamEnabled    Boolean   @default(false)
  micEnabled       Boolean   @default(false)
  browserLock      Boolean   @default(true)
  suspiciousCount  Int       @default(0)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  exams         Exam[]       @relation("ExamProctor")
  studentExams  StudentExam[]
  alerts        Alert[]
}

model Institution {
  id                    String       @id @default(uuid())
  name                  String       @unique
  code                  String       @unique
  type                  String?      // e.g. Engineering, Medical, Arts
  affiliation           String?      // University Affiliation
  accreditation         String?      // e.g. NAAC A+, ABET
  email                 String?      @unique
  phone                 String?
  website               String?
  address               String?
  city                  String?
  state                 String?
  country               String?
  pincode               String?
  logo                  String?
  banner                String?
  status                InstitutionStatus @default(ACTIVE)
  
  // Subscription Info
  plan                  String?      @default("BASIC")
  expiryDate            DateTime?
  
  // Relations
  users                 User[]
  exams                 Exam[]
  departments           Department[]
  announcements         Announcement[]
  
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Department {
  id              String      @id @default(uuid())
  name            String
  code            String?
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  hodId           String?
  hod             User?       @relation("DeptHOD", fields: [hodId], references: [id])
  studentsCount   Int         @default(0)
  facultyCount    Int         @default(0)
  
  users           User[]      @relation("UserDept")
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([name, institutionId])
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Announcement {
  id              String      @id @default(uuid())
  title           String
  content         String
  institutionId   String?
  institution     Institution? @relation(fields: [institutionId], references: [id])
  role            Role?       // Target audience
  createdAt       DateTime    @default(now())
}

model Exam {
  id            String       @id @default(uuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  status        ExamStatus   @default(SCHEDULED)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  proctorId     String
  proctor       User         @relation("ExamProctor", fields: [proctorId], references: [id])
  duration      Int          @default(0)
  type          String       @default("MCQ")
  department    String?
  students      StudentExam[]
  alerts        Alert[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model StudentExam {
  id        String     @id @default(uuid())
  studentId String
  student   User       @relation(fields: [studentId], references: [id])
  examId    String
  exam      Exam       @relation(fields: [examId], references: [id])
  status    ExamStatus @default(SCHEDULED)
  score     Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([studentId, examId])
}

model Question {
  id            String   @id @default(uuid())
  content       String
  category      String?
  type          String   @default("MCQ")
  difficulty    String   @default("MEDIUM")
  institutionId String?
  options       String[]
  correctAnswer String?
  explanation   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Alert {
  id        String    @id @default(uuid())
  examId    String
  exam      Exam      @relation(fields: [examId], references: [id])
  studentId String?
  student   User?      @relation(fields: [studentId], references: [id])
  title     String
  desc      String
  type      AlertType @default(WARNING)
  severity  Int       @default(1) // 1-10
  createdAt DateTime  @default(now())
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ONGOING
  HELD
  COMPLETED
  CANCELLED
}

enum AlertType {
  INFO
  WARNING
  CRITICAL
}
